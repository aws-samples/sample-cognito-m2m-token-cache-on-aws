# Ignore everything by default
*

# Allow specific files and directories
!.gitignore
!README.md
!LICENSE
!CONTRIBUTING.md
!cognito-proxy-template.yaml
!docs/
!docs/**
!cdk/
!cdk/**

# Ignore CDK build artifacts
cdk/cdk.out/
cdk/.venv/
cdk/**/__pycache__/
cdk/**/*.pyc
cdk/**/*.egg-info/

# Ignore deployment scripts and outputs (contain sensitive config)
deploy-cdk.sh
deployment-commands.txt
cdk-outputs.json

# AppSec
appsec/

# macOS
.DS_Store
