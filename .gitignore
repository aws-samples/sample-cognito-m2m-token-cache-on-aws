# Ignore everything by default
*

# Allow specific files and directories
!.gitignore
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!cognito-proxy-template.yaml
!.github/
!.github/**
!docs/
!docs/**
!cdk/
!cdk/**

# Ignore CDK build artifacts
cdk/cdk.out/
cdk/.venv/
cdk/cdk.context.json
cdk/**/__pycache__/
cdk/**/*.pyc
cdk/**/*.egg-info/

# Ignore deployment scripts and outputs (contain sensitive config)
deploy-cdk.sh
deployment-commands.txt
cdk-outputs.json

# AppSec
appsec/

# Testing
testing/

# License reports
license-reports/

# macOS
.DS_Store
